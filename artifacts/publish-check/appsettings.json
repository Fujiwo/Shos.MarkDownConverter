{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MarkItDown": {
    "PythonExecutablePath": "python",
    "ModuleName": "markitdown",
    "MaxUploadSizeBytes": 104857600,
    "AllowedExtensions": [
      ".pdf",
      ".docx",
      ".pptx",
      ".xlsx",
      ".csv",
      ".json",
      ".xml",
      ".html",
      ".htm",
      ".txt",
      ".md",
      ".jpg",
      ".jpeg",
      ".png"
    ]
  }
}
